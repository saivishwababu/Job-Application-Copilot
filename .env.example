# Copy this file to .env and add your Groq API key.
GROQ_API_KEY=gsk-your-groq-api-key-here

# Optional: override the chat model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: local embedding model for RAG (no API key needed)
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
